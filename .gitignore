# Allowlist repository contents; runtime output and generated artifacts stay local.
*
!*/

!.clang-format
!.clang-tidy
!.gitattributes
!.gitignore
!AGENTS.md
!CHANGELOG.md
!CMakeLists.txt
!CMakePresets.json
!COMPATIBILITY.md
!CONTRIBUTING.md
!LICENSE
!NOTICE
!PROBLEMS.md
!README.md
!SECURITY.md
!TODO.md
!TRADEMARK.md

!src/**
!tests/**
!third_party/cpp-httplib/**
!third_party/nlohmann/**
!third_party/sqlite/**
!third_party/xxhash/**
!CHAX-CLIENT/**
!scripts/**
!tools/automation/**
!checklists/**
!docs/**
!spec/**

# Local/generated state.
.chax/
build/
release/
out/
dist/
tmp/
temp/
.cache/

# Runtime and generated binaries.
*.exe
*.dll
*.so
*.dylib
*.obj
*.o
*.lib
*.a
*.pdb
*.ilk
*.db
*.sqlite
*.sqlite3

# Transport/output archives and generated documents.
*.chk
*.7z
*.zip
*.tar
*.gz
*.pdf
!tests/fixtures/formFillDemo/templates/report.pdf

# Logs and local settings.
*.log
*.err
*.tmp
.DS_Store
Thumbs.db
desktop.ini

# Checklist-local runtime output.
checklists/**/reports/
checklists/**/logs/
checklists/**/saves/
